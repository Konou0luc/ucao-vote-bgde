NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://votebgde_user:your_password@localhost:5432/votebgde_db
NEON_DATABASE_URL=postgresql://username:password@your-neon-host/dbname?sslmode=require
UCAO_API_BASE_URL=http://localhost:4000
UCAO_API_KEY=replace-with-shared-service-api-key
UCAO_API_TIMEOUT_MS=5000
MAIL_TRANSPORT=json
MAIL_FROM=no-reply@ucao-uut.tg
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_SECURE=false
JWT_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_EMAIL=admin@ucao-uut.tg
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_PUBLIC_MAX=5000
RATE_LIMIT_OTP_SEND_MAX=30
RATE_LIMIT_OTP_VERIFY_MAX=300
RATE_LIMIT_VOTE_MAX=300
RATE_LIMIT_ADMIN_MAX=300
